{
  "name": "@machina-xyz/vault-core",
  "version": "0.1.0",
  "description": "MACHINA Vault Core — secure key management powered by Rust/WASM. One passkey, one vault, all chains.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./passkey": {
      "types": "./dist/passkey/index.d.ts",
      "import": "./dist/passkey/index.js"
    },
    "./signing": {
      "types": "./dist/signing/index.d.ts",
      "import": "./dist/signing/index.js"
    },
    "./keys": {
      "types": "./dist/keys/index.d.ts",
      "import": "./dist/keys/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/curves": "^1.8.0",
    "@noble/hashes": "^1.7.0",
    "@simplewebauthn/server": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}
